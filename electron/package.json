{
  "name": "paris-sender-electron",
  "version": "0.2.0",
  "private": true,
  "description": "Phase 2 Electron + React frontend for Paris Sender",
  "main": "main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:renderer": "vite build",
    "build:backend": "python ../packaging/build_backend.py",
    "build": "vite build && electron-builder",
    "dist": "npm run build:backend && npm run build:renderer && electron-builder",
    "dist:win": "npm run build:backend && npm run build:renderer && electron-builder --win",
    "dist:mac": "npm run build:backend && npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "build": {
    "appId": "com.parissender.app",
    "productName": "Paris Sender",
    "directories": {
      "output": "out",
      "buildResources": "build"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "LOBEG",
        "repo": "PARIS-SENDER"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "postcss": "latest",
    "tailwindcss": "^3",
    "vite": "latest",
    "wait-on": "latest"
  }
}
